# PostgreSQL
PG_HOST=localhost
PG_PORT=5432
PG_USER=interviewer_ai_dev_user
PG_PASSWORD=interviewer_ai_dev_pass
PG_DB=interviewer_ai_dev_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USER=default
REDIS_PASSWORD=password

# Better Auth
BETTER_AUTH_SECRET=<your-secret>
BETTER_AUTH_URL=http://localhost:8000
PORT=8000

# CORS
CORS_ORIGIN=http://localhost:3000,localhost:3001

# Email (Mailpit for dev)
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_FROM=noreply@interviewer.ai

# OAuth — Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth — GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Judge0
JUDGE0_URL=http://localhost:2358
JUDGE0_AUTH_TOKEN=

# Hume AI
HUME_API_KEY=
HUME_SECRET_KEY=
HUME_WEBHOOK_SIGNING_KEY=
HUME_WEBHOOK_URL=

# AI Feedback Provider — "ollama" or "google"
AI_PROVIDER=ollama
AI_MODEL=qwen3.5:9b
GOOGLE_GENERATIVE_AI_API_KEY=
